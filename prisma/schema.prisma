// Prisma Schema for SEOClaw Dashboard
// Created during local prototyping
// Sprint 2: Backend API

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============================================
// PROJECT MODEL
// ============================================

model Project {
  id          String   @id @default(cuid())
  name        String
  description String?
  
  // Status & Classification
  status      String   // "active", "planning", "at_risk", "completed", "on_hold"
  direction   String   // "metallurgy", "logistics", "trade", "construction"
  priority    String   @default("medium") // "low", "medium", "high", "critical"
  health      String   @default("good") // "good", "warning", "critical"
  
  // Dates
  start       DateTime
  end         DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // Budget
  budgetPlan  Float?
  budgetFact  Float?   @default(0)
  
  // Progress (0-100)
  progress    Int      @default(0)
  
  // Location
  location    String?
  
  // Relations
  tasks       Task[]
  risks       Risk[]
  documents   Document[]
  milestones  Milestone[]
  team        TeamMember[]
  boards      Board[]
  
  @@index([status])
  @@index([direction])
  @@index([health])
}

// ============================================
// TASK MODEL
// ============================================

model Task {
  id          String    @id @default(cuid())
  title       String
  description String?
  
  // Status & Priority
  status      String    @default("todo") // "todo", "in_progress", "blocked", "done", "cancelled"
  priority    String    @default("medium") // "low", "medium", "high", "critical"
  order       Int       @default(0)
  
  // Dates
  dueDate     DateTime
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  // Relations
  projectId   String
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  assigneeId  String?
  assignee    TeamMember? @relation(fields: [assigneeId], references: [id])
  
  // Kanban
  columnId    String?
  column      Column?    @relation(fields: [columnId], references: [id])
  
  // Dependencies
  dependencies TaskDependency[] @relation("TaskDependencies")
  dependents   TaskDependency[] @relation("TaskDependents")
  
  // Time tracking
  timeEntries  TimeEntry[]
  
  @@index([status])
  @@index([priority])
  @@index([dueDate])
  @@index([projectId])
  @@index([projectId, status, order])
  @@index([columnId])
}

// ============================================
// TEAM MEMBER MODEL
// ============================================

model TeamMember {
  id        String   @id @default(cuid())
  name      String
  initials  String?  // "С", "ИА", "МП" etc.
  role      String
  email     String?
  avatar    String?  // URL to avatar image
  
  // Capacity (0-100)
  capacity  Int      @default(100)
  
  // Relations
  tasks     Task[]
  projects  Project[]
  risks     Risk[]     @relation("RiskOwner")
  documents Document[] @relation("DocumentOwner")
  timeEntries TimeEntry[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@index([name])
}

// ============================================
// RISK MODEL
// ============================================

model Risk {
  id          String   @id @default(cuid())
  title       String
  description String?
  
  // Assessment
  probability String   @default("medium") // "low", "medium", "high"
  impact      String   @default("medium") // "low", "medium", "high"
  severity    Int      @default(3) // 1-5
  
  // Status
  status      String   @default("open") // "open", "mitigated", "closed"
  
  // Owner
  ownerId     String?
  owner       TeamMember? @relation("RiskOwner", fields: [ownerId], references: [id])
  
  // Relations
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([status])
  @@index([severity])
  @@index([projectId])
}

// ============================================
// MILESTONE MODEL
// ============================================

model Milestone {
  id          String   @id @default(cuid())
  title       String
  description String?
  
  // Date
  date        DateTime
  
  // Status
  status      String   @default("upcoming") // "upcoming", "in_progress", "completed", "overdue"
  
  // Relations
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([date])
  @@index([status])
  @@index([projectId])
}

// ============================================
// DOCUMENT MODEL
// ============================================

model Document {
  id          String   @id @default(cuid())
  title       String
  description String?
  
  // File info
  filename    String
  url         String   // URL to file
  type        String   // "pdf", "docx", "xlsx", "other"
  size        Int?     // in bytes
  
  // Owner
  ownerId     String?
  owner       TeamMember? @relation("DocumentOwner", fields: [ownerId], references: [id])
  
  // Relations
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([type])
  @@index([projectId])
}

// ============================================
// KANBAN BOARD MODEL
// ============================================

model Board {
  id          String   @id @default(cuid())
  name        String
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  columns     Column[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([projectId])
}

model Column {
  id          String   @id @default(cuid())
  title       String   // "To Do", "In Progress", "Review", "Done"
  order       Int      @default(0)
  color       String?  // "#3b82f6" etc.
  
  boardId     String
  board       Board    @relation(fields: [boardId], references: [id], onDelete: Cascade)
  tasks       Task[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([boardId])
  @@index([boardId, order])
}

// ============================================
// TASK DEPENDENCY MODEL
// ============================================

model TaskDependency {
  id               String   @id @default(cuid())
  type             String   @default("FINISH_TO_START") // "FINISH_TO_START", "START_TO_START", etc.
  
  taskId           String
  task             Task     @relation("TaskDependencies", fields: [taskId], references: [id], onDelete: Cascade)
  
  dependsOnTaskId  String
  dependsOnTask    Task     @relation("TaskDependents", fields: [dependsOnTaskId], references: [id], onDelete: Cascade)
  
  createdAt        DateTime @default(now())
  
  @@unique([taskId, dependsOnTaskId])
  @@index([taskId])
  @@index([dependsOnTaskId])
}

// ============================================
// TIME ENTRY MODEL
// ============================================

model TimeEntry {
  id          String   @id @default(cuid())
  
  // Relations
  taskId      String
  task        Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  
  memberId    String?
  member      TeamMember? @relation(fields: [memberId], references: [id])
  
  // Time tracking
  startTime   DateTime
  endTime     DateTime?
  duration    Int?     // Duration in seconds (calculated)
  
  // Metadata
  description String?
  billable    Boolean  @default(true)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([taskId])
  @@index([memberId])
  @@index([startTime])
}

// ============================================
// NOTIFICATION MODEL
// ============================================

model Notification {
  id          String   @id @default(cuid())
  
  // Recipient
  userId      String
  
  // Content
  type        String   // "task_assigned", "due_date", "status_changed", "mention"
  title       String
  message     String
  
  // Related entity
  entityType  String?  // "project", "task", "risk"
  entityId    String?
  
  // Status
  read        Boolean  @default(false)
  readAt      DateTime?
  
  // Timestamps
  createdAt   DateTime @default(now())
  
  @@index([userId])
  @@index([read])
  @@index([createdAt])
}

