// Prisma Schema for SEOClaw Dashboard
// Created during local prototyping
// Sprint 2: Backend API

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Organization {
  id          String       @id @default(cuid())
  slug        String       @unique
  name        String
  description String?
  workspaces  Workspace[]
  memberships Membership[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Workspace {
  id             String                @id @default(cuid())
  organizationId String
  organization   Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  key            String
  name           String
  initials       String
  description    String?
  isDefault      Boolean               @default(false)
  memberships    WorkspaceMembership[]
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  @@unique([organizationId, key])
  @@index([organizationId])
}

// ============================================
// PROJECT MODEL
// ============================================

model Project {
  id          String   @id @default(cuid())
  name        String
  description String?
  
  // Status & Classification
  status      String   // "active", "planning", "at_risk", "completed", "on_hold"
  direction   String   // "metallurgy", "logistics", "trade", "construction"
  priority    String   @default("medium") // "low", "medium", "high", "critical"
  health      String   @default("good") // "good", "warning", "critical"
  
  // Dates
  start       DateTime
  end         DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // Budget
  budgetPlan  Float?
  budgetFact  Float?   @default(0)
  
  // Progress (0-100)
  progress    Int      @default(0)
  
  // Location
  location    String?
  
  // Relations
  tasks       Task[]
  risks       Risk[]
  documents   Document[]
  milestones  Milestone[]
  team        TeamMember[]
  boards      Board[]
  workReports WorkReport[]
  telegramBriefPolicies TelegramBriefDeliveryPolicy[]
  evidenceRecords EvidenceRecord[]
  
  @@index([status])
  @@index([direction])
  @@index([health])
}

// ============================================
// TASK MODEL
// ============================================

model Task {
  id          String    @id @default(cuid())
  title       String
  description String?
  
  // Status & Priority
  status      String    @default("todo") // "todo", "in_progress", "blocked", "done", "cancelled"
  priority    String    @default("medium") // "low", "medium", "high", "critical"
  order       Int       @default(0)
  
  // Dates
  dueDate     DateTime
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  // Relations
  projectId   String
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  assigneeId  String?
  assignee    TeamMember? @relation(fields: [assigneeId], references: [id])
  
  // Kanban
  columnId    String?
  column      Column?    @relation(fields: [columnId], references: [id])
  
  // Dependencies
  dependencies TaskDependency[] @relation("TaskDependencies")
  dependents   TaskDependency[] @relation("TaskDependents")
  
  // Time tracking
  timeEntries  TimeEntry[]
  
  @@index([status])
  @@index([priority])
  @@index([dueDate])
  @@index([projectId])
  @@index([projectId, status, order])
  @@index([columnId])
}

// ============================================
// TEAM MEMBER MODEL
// ============================================

model TeamMember {
  id        String   @id @default(cuid())
  name      String
  initials  String?  // "С", "ИА", "МП" etc.
  role      String
  email     String?
  avatar    String?  // URL to avatar image
  
  // Capacity (0-100)
  capacity  Int      @default(100)
  
  // Relations
  tasks     Task[]
  projects  Project[]
  risks     Risk[]     @relation("RiskOwner")
  documents Document[] @relation("DocumentOwner")
  timeEntries TimeEntry[]
  authoredWorkReports WorkReport[] @relation("WorkReportAuthor")
  reviewedWorkReports WorkReport[] @relation("WorkReportReviewer")
  memberships Membership[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@index([name])
}

model Membership {
  id                  String                @id @default(cuid())
  organizationId      String
  organization        Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  teamMemberId        String?
  teamMember          TeamMember?           @relation(fields: [teamMemberId], references: [id], onDelete: SetNull)
  externalUserId      String?               @unique
  email               String?
  displayName         String
  role                String                @default("MEMBER")
  workspaceMemberships WorkspaceMembership[]
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt

  @@index([organizationId, role])
  @@index([teamMemberId])
}

model WorkspaceMembership {
  id           String      @id @default(cuid())
  workspaceId  String
  workspace    Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  membershipId String
  membership   Membership  @relation(fields: [membershipId], references: [id], onDelete: Cascade)
  role         String?
  createdAt    DateTime    @default(now())

  @@unique([workspaceId, membershipId])
  @@index([membershipId])
}

// ============================================
// RISK MODEL
// ============================================

model Risk {
  id          String   @id @default(cuid())
  title       String
  description String?
  
  // Assessment
  probability String   @default("medium") // "low", "medium", "high"
  impact      String   @default("medium") // "low", "medium", "high"
  severity    Int      @default(3) // 1-5
  
  // Status
  status      String   @default("open") // "open", "mitigated", "closed"
  
  // Owner
  ownerId     String?
  owner       TeamMember? @relation("RiskOwner", fields: [ownerId], references: [id])
  
  // Relations
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([status])
  @@index([severity])
  @@index([projectId])
}

// ============================================
// MILESTONE MODEL
// ============================================

model Milestone {
  id          String   @id @default(cuid())
  title       String
  description String?
  
  // Date
  date        DateTime
  
  // Status
  status      String   @default("upcoming") // "upcoming", "in_progress", "completed", "overdue"
  
  // Relations
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([date])
  @@index([status])
  @@index([projectId])
}

// ============================================
// DOCUMENT MODEL
// ============================================

model Document {
  id          String   @id @default(cuid())
  title       String
  description String?
  
  // File info
  filename    String
  url         String   // URL to file
  type        String   // "pdf", "docx", "xlsx", "other"
  size        Int?     // in bytes
  
  // Owner
  ownerId     String?
  owner       TeamMember? @relation("DocumentOwner", fields: [ownerId], references: [id])
  
  // Relations
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([type])
  @@index([projectId])
}

// ============================================
// KANBAN BOARD MODEL
// ============================================

model Board {
  id          String   @id @default(cuid())
  name        String
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  columns     Column[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([projectId])
}

model Column {
  id          String   @id @default(cuid())
  title       String   // "To Do", "In Progress", "Review", "Done"
  order       Int      @default(0)
  color       String?  // "#3b82f6" etc.
  
  boardId     String
  board       Board    @relation(fields: [boardId], references: [id], onDelete: Cascade)
  tasks       Task[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([boardId])
  @@index([boardId, order])
}

// ============================================
// TASK DEPENDENCY MODEL
// ============================================

model TaskDependency {
  id               String   @id @default(cuid())
  type             String   @default("FINISH_TO_START") // "FINISH_TO_START", "START_TO_START", etc.
  
  taskId           String
  task             Task     @relation("TaskDependencies", fields: [taskId], references: [id], onDelete: Cascade)
  
  dependsOnTaskId  String
  dependsOnTask    Task     @relation("TaskDependents", fields: [dependsOnTaskId], references: [id], onDelete: Cascade)
  
  createdAt        DateTime @default(now())
  
  @@unique([taskId, dependsOnTaskId])
  @@index([taskId])
  @@index([dependsOnTaskId])
}

// ============================================
// TIME ENTRY MODEL
// ============================================

model TimeEntry {
  id          String   @id @default(cuid())
  
  // Relations
  taskId      String
  task        Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  
  memberId    String?
  member      TeamMember? @relation(fields: [memberId], references: [id])
  
  // Time tracking
  startTime   DateTime
  endTime     DateTime?
  duration    Int?     // Duration in seconds (calculated)
  
  // Metadata
  description String?
  billable    Boolean  @default(true)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([taskId])
  @@index([memberId])
  @@index([startTime])
}

// ============================================
// NOTIFICATION MODEL
// ============================================

model Notification {
  id          String   @id @default(cuid())
  
  // Recipient
  userId      String
  
  // Content
  type        String   // "task_assigned", "due_date", "status_changed", "mention"
  title       String
  message     String
  
  // Related entity
  entityType  String?  // "project", "task", "risk"
  entityId    String?
  
  // Status
  read        Boolean  @default(false)
  readAt      DateTime?
  
  // Timestamps
  createdAt   DateTime @default(now())
  
  @@index([userId])
  @@index([read])
  @@index([createdAt])
}

model TelegramBriefDeliveryPolicy {
  id              String    @id @default(cuid())
  workspaceId     String    @default("executive")
  scope           String
  projectId       String?
  project         Project?  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  locale          String    @default("ru")
  chatId          String?
  cadence         String    @default("daily")
  timezone        String    @default("UTC")
  deliveryHour    Int
  active          Boolean   @default(true)
  createdByUserId String?
  updatedByUserId String?
  lastAttemptAt   DateTime?
  lastDeliveredAt DateTime?
  lastMessageId   Int?
  lastError       String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([workspaceId, active])
  @@index([projectId])
  @@index([deliveryHour, active])
}

model PilotReviewDeliveryPolicy {
  id              String   @id @default(cuid())
  workspaceId     String   @default("executive")
  channel         String   @default("email")
  recipient       String?
  timezone        String   @default("UTC")
  deliveryHour    Int
  deliveryWeekday Int      @default(1)
  active          Boolean  @default(true)
  createdByUserId String?
  updatedByUserId String?
  lastAttemptAt   DateTime?
  lastDeliveredAt DateTime?
  lastError       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([workspaceId, active])
  @@index([deliveryWeekday, deliveryHour, active])
}

model DeliveryLedger {
  id                String   @id @default(cuid())
  channel           String
  provider          String
  mode              String
  scope             String
  projectId         String?
  projectName       String?
  locale            String
  target            String?
  headline          String
  idempotencyKey    String   @unique
  scheduledPolicyId String?
  status            String
  retryPosture      String
  attemptCount      Int      @default(0)
  dryRun            Boolean  @default(false)
  providerMessageId String?
  contentHash       String
  requestJson       String
  responseJson      String?
  lastError         String?
  firstAttemptAt    DateTime?
  lastAttemptAt     DateTime?
  deliveredAt       DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([channel, updatedAt])
  @@index([status, updatedAt])
  @@index([projectId, updatedAt])
  @@index([scheduledPolicyId, updatedAt])
}

model PilotFeedback {
  id             String   @id @default(cuid())
  targetType     String
  targetId       String
  targetLabel    String
  sourceLabel    String
  sourceHref     String?
  projectId      String?
  projectName    String?
  severity       String
  status         String   @default("open")
  summary        String
  details        String?
  ownerId        String?
  ownerName      String?
  ownerRole      String?
  reporterName   String?
  resolutionNote String?
  metadataJson   String?
  openedAt       DateTime @default(now())
  resolvedAt     DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([status, updatedAt])
  @@index([severity, status, updatedAt])
  @@index([targetType, targetId, updatedAt])
  @@index([projectId, updatedAt])
  @@index([ownerId, updatedAt])
}

// ============================================
// WORK REPORT MODEL
// ============================================

model WorkReport {
  id                        String      @id @default(cuid())
  reportNumber              String      @unique
  projectId                 String
  project                   Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  authorId                  String
  author                    TeamMember  @relation("WorkReportAuthor", fields: [authorId], references: [id])
  reviewerId                String?
  reviewer                  TeamMember? @relation("WorkReportReviewer", fields: [reviewerId], references: [id])
  section                   String
  reportDate                DateTime
  workDescription           String
  volumesJson               String      @default("[]")
  personnelCount            Int?
  personnelDetails          String?
  equipment                 String?
  weather                   String?
  issues                    String?
  nextDayPlan               String?
  attachmentsJson           String      @default("[]")
  status                    String      @default("submitted")
  reviewComment             String?
  source                    String      @default("manual")
  externalReporterTelegramId String?
  externalReporterName      String?
  submittedAt               DateTime    @default(now())
  reviewedAt                DateTime?
  createdAt                 DateTime    @default(now())
  updatedAt                 DateTime    @updatedAt

  @@index([projectId])
  @@index([authorId])
  @@index([reviewerId])
  @@index([reportDate])
  @@index([status])
  @@index([projectId, reportDate])
}

model EvidenceRecord {
  id                 String    @id @default(cuid())
  sourceType         String
  sourceRef          String?
  entityType         String
  entityRef          String
  projectId          String?
  project            Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)
  title              String
  summary            String?
  observedAt         DateTime
  reportedAt         DateTime?
  confidence         Float
  verificationStatus String
  metadataJson       String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@unique([sourceType, entityType, entityRef])
  @@index([verificationStatus])
  @@index([entityType, entityRef])
  @@index([projectId])
  @@index([observedAt])
}

model EscalationItem {
  id              String   @id @default(cuid())
  sourceType      String
  sourceRef       String?
  entityType      String
  entityRef       String
  projectId       String?
  projectName     String?
  title           String
  summary         String?
  purpose         String?
  urgency         String
  queueStatus     String   @default("open")
  sourceStatus    String
  ownerId         String?
  ownerName       String?
  ownerRole       String?
  firstObservedAt DateTime
  lastObservedAt  DateTime
  acknowledgedAt  DateTime?
  resolvedAt      DateTime?
  slaTargetAt     DateTime
  metadataJson    String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([sourceType, entityType, entityRef])
  @@index([queueStatus, urgency])
  @@index([projectId])
  @@index([ownerId])
  @@index([slaTargetAt])
}

model AiRunLedger {
  id               String   @id
  origin           String
  agentId          String
  title            String
  status           String
  quickActionId    String?
  projectId        String?
  workflow         String?
  sourceEntityType String?
  sourceEntityId   String?
  inputJson        String
  runJson          String
  runCreatedAt     DateTime
  runUpdatedAt     DateTime
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([status, runUpdatedAt])
  @@index([workflow])
  @@index([projectId])
  @@index([runCreatedAt])
}

model DerivedSyncState {
  key             String   @id
  status          String
  lastStartedAt   DateTime?
  lastCompletedAt DateTime?
  lastSuccessAt   DateTime?
  lastError       String?
  lastResultCount Int?
  metadataJson    String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([status, updatedAt])
  @@index([lastSuccessAt])
}

model ReconciliationCasefile {
  id                 String   @id @default(cuid())
  key                String   @unique
  caseType           String
  truthStatus        String
  resolutionStatus   String   @default("open")
  projectId          String?
  projectName        String?
  financeProjectId   String?
  title              String
  explanation        String
  reasonCodesJson    String
  evidenceRecordIdsJson String
  fusionFactIdsJson  String
  telemetryRefsJson  String
  financeJson        String?
  fieldJson          String?
  telemetryJson      String?
  lastObservedAt     DateTime
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([resolutionStatus, updatedAt])
  @@index([truthStatus, updatedAt])
  @@index([projectId])
  @@index([caseType, updatedAt])
  @@index([lastObservedAt])
}

